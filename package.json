{
	"name": "boba-tech",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "next dev",
		"dev:next": "next dev",
		"build": "next build && opennextjs-cloudflare build --skipBuild",
		"start": "next start",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"fix": "pnpm run lint:fix && pnpm run format",
		"deploy": "opennextjs-cloudflare",
		"cf:build": "opennextjs-cloudflare build",
		"cf:deploy": "opennextjs-cloudflare deploy",
		"cf:preview": "opennextjs-cloudflare preview",
		"cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio",
		"test": "vitest run",
		"test:watch": "vitest watch",
		"test:coverage": "vitest run --coverage",
		"generate:og": "tsx scripts/generate-og-image.ts"
	},
	"dependencies": {
		"@next/third-parties": "^16.2.9",
		"@opennextjs/cloudflare": "^1.19.11",
		"@portabletext/react": "^6.2.0",
		"@portabletext/types": "^4.0.2",
		"@react-email/components": "^1.0.12",
		"@react-email/render": "^2.0.9",
		"@sanity/client": "^7.23.0",
		"@sanity/image-url": "^2.1.1",
		"@t3-oss/env-nextjs": "^0.13.11",
		"@tanstack/react-table": "^8.21.3",
		"better-auth": "^1.6.19",
		"clsx": "^2.1.1",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.2",
		"embla-carousel-react": "^8.6.0",
		"framer-motion": "^12.40.0",
		"lucide-react": "^1.21.0",
		"next": "16.2.3",
		"next-intl": "^4.13.0",
		"react": "19.2.5",
		"react-dom": "19.2.5",
		"react-email": "^5.2.11",
		"react-syntax-highlighter": "^16.1.1",
		"resend": "^6.14.0",
		"simple-icons": "^16.23.0",
		"tailwind-merge": "^3.6.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260617.1",
		"@eslint/eslintrc": "^3.3.5",
		"@eslint/js": "^10.0.1",
		"@fontsource/sora": "^5.2.8",
		"@tailwindcss/postcss": "^4.3.1",
		"@types/node": "^25.9.3",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"@types/react-syntax-highlighter": "^15.5.13",
		"@vitest/coverage-v8": "^4.1.9",
		"eslint": "^10.5.0",
		"eslint-config-next": "16.2.3",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.6",
		"globals": "^17.6.0",
		"prettier": "^3.8.4",
		"satori": "^0.26.0",
		"sharp": "^0.35.1",
		"tailwindcss": "^4.3.1",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.61.1",
		"vitest": "^4.1.9",
		"wrangler": "^4.101.0"
	}
}
