{
	"name": "next",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "node --import jiti/register scripts/dev-with-blog-watch.ts",
		"dev:next": "next dev",
		"dev:blog": "node --import jiti/register scripts/watch-blog.ts",
		"build": "pnpm run cf-typegen && pnpm run generate-blog-data && next build && opennextjs-cloudflare build --skipBuild",
		"start": "next start",
		"lint": "next lint",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"fix": "pnpm run format",
		"deploy": "opennextjs-cloudflare",
		"cf:build": "opennextjs-cloudflare build",
		"cf:deploy": "opennextjs-cloudflare deploy",
		"cf:preview": "opennextjs-cloudflare preview",
		"cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts",
		"generate-blog-data": "node --import jiti/register scripts/generate-blog-data.ts",
		"watch-blog": "node --import jiti/register scripts/watch-blog.ts",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio",
		"test": "vitest",
		"test:coverage": "vitest run --coverage"
	},
	"dependencies": {
		"@libsql/client": "^0.17.0",
		"@opennextjs/cloudflare": "^1.16.2",
		"@react-three/drei": "^10.7.7",
		"@react-three/fiber": "^9.4.2",
		"@t3-oss/env-nextjs": "^0.13.8",
		"@types/react-syntax-highlighter": "^15.5.13",
		"@types/three": "^0.182.0",
		"dotenv": "^17.2.3",
		"drizzle-kit": "^0.31.7",
		"drizzle-orm": "^0.45.1",
		"framer-motion": "^12.23.25",
		"gray-matter": "^4.0.3",
		"jiti": "^2.6.1",
		"lucide-react": "^0.563.0",
		"next": "16.1.6",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"react-email": "^5.0.5",
		"react-markdown": "^10.1.0",
		"react-syntax-highlighter": "^16.1.0",
		"remark-gfm": "^4.0.1",
		"three": "^0.182.0",
		"zod": "^4.1.13"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260131.0",
		"@eslint/eslintrc": "^3",
		"@tailwindcss/postcss": "^4",
		"@types/node": "^20.19.25",
		"@types/react": "19.2.10",
		"@types/react-dom": "19.2.3",
		"@vitest/coverage-v8": "^4.0.15",
		"eslint": "^9.39.2",
		"eslint-config-next": "16.1.6",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.4",
		"prettier": "^3.8.1",
		"tailwindcss": "^4",
		"typescript": "^5.9.3",
		"vitest": "^4.0.15",
		"wrangler": "^4.61.1"
	},
	"pnpm": {
		"overrides": {
			"@types/react": "19.2.10",
			"@types/react-dom": "19.2.3"
		}
	}
}
