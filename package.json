{
	"name": "next",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "next dev",
		"dev:next": "next dev",
		"build": "pnpm run cf-typegen && next build && opennextjs-cloudflare build --skipBuild",
		"start": "next start",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"fix": "pnpm run lint:fix && pnpm run format",
		"deploy": "opennextjs-cloudflare",
		"cf:build": "opennextjs-cloudflare build",
		"cf:deploy": "opennextjs-cloudflare deploy",
		"cf:preview": "opennextjs-cloudflare preview",
		"cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio",
		"test": "vitest",
		"test:coverage": "vitest run --coverage"
	},
	"dependencies": {
		"@opennextjs/cloudflare": "^1.18.1",
		"@portabletext/react": "^6.0.3",
		"@portabletext/types": "^4.0.2",
		"@react-email/components": "^1.0.12",
		"@react-email/render": "^2.0.6",
		"@sanity/client": "^7.20.0",
		"@sanity/image-url": "^2.1.1",
		"@t3-oss/env-nextjs": "^0.13.11",
		"better-auth": "^1.6.2",
		"clsx": "^2.1.1",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.2",
		"embla-carousel-react": "^8.6.0",
		"framer-motion": "^12.38.0",
		"lucide-react": "^1.7.0",
		"next": "16.2.3",
		"next-intl": "^4.9.0",
		"react": "19.2.5",
		"react-dom": "19.2.5",
		"react-email": "^5.2.10",
		"react-syntax-highlighter": "^16.1.1",
		"resend": "^6.10.0",
		"simple-icons": "^16.15.0",
		"tailwind-merge": "^3.5.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260408.1",
		"@eslint/eslintrc": "^3.3.5",
		"@eslint/js": "^10.0.1",
		"@tailwindcss/postcss": "^4.2.2",
		"@types/node": "^25.5.2",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"@types/react-syntax-highlighter": "^15.5.13",
		"@vitest/coverage-v8": "^4.1.3",
		"eslint": "^10.2.0",
		"eslint-config-next": "16.2.3",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.5",
		"globals": "^17.4.0",
		"prettier": "^3.8.1",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vitest": "^4.1.3",
		"wrangler": "^4.81.0"
	},
	"pnpm": {
		"overrides": {
			"@types/react": "19.2.14",
			"@types/react-dom": "19.2.3"
		}
	}
}
