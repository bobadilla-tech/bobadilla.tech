{
	"name": "next",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "next dev",
		"dev:next": "next dev",
		"build": "pnpm run cf-typegen && next build && opennextjs-cloudflare build --skipBuild",
		"start": "next start",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"fix": "pnpm run lint:fix && pnpm run format",
		"deploy": "opennextjs-cloudflare",
		"cf:build": "opennextjs-cloudflare build",
		"cf:deploy": "opennextjs-cloudflare deploy",
		"cf:preview": "opennextjs-cloudflare preview",
		"cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio",
		"test": "vitest",
		"test:coverage": "vitest run --coverage"
	},
	"dependencies": {
		"@libsql/client": "^0.17.0",
		"@opennextjs/cloudflare": "^1.16.5",
		"@react-three/drei": "^10.7.7",
		"@react-three/fiber": "^9.5.0",
		"@t3-oss/env-nextjs": "^0.13.10",
		"@types/react-syntax-highlighter": "^15.5.13",
		"@types/three": "^0.182.0",
		"dotenv": "^17.3.1",
		"drizzle-kit": "^0.31.9",
		"drizzle-orm": "^0.45.1",
		"framer-motion": "^12.34.2",
		"gray-matter": "^4.0.3",
		"jiti": "^2.6.1",
		"lucide-react": "^0.563.0",
		"next": "16.1.6",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"react-email": "^5.2.8",
		"react-markdown": "^10.1.0",
		"react-syntax-highlighter": "^16.1.0",
		"remark-gfm": "^4.0.1",
		"three": "^0.182.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260218.0",
		"@eslint/eslintrc": "^3.3.3",
		"@eslint/js": "^9.39.2",
		"@tailwindcss/postcss": "^4.2.0",
		"@types/node": "^20.19.33",
		"@types/react": "19.2.10",
		"@types/react-dom": "19.2.3",
		"@vitest/coverage-v8": "^4.0.18",
		"eslint": "^9.39.2",
		"eslint-config-next": "16.1.6",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.5",
		"globals": "^17.3.0",
		"prettier": "^3.8.1",
		"tailwindcss": "^4.2.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.56.0",
		"vitest": "^4.0.18",
		"wrangler": "^4.66.0"
	},
	"pnpm": {
		"overrides": {
			"@types/react": "19.2.10",
			"@types/react-dom": "19.2.3"
		}
	}
}
